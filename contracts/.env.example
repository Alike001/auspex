# Copy this file to .env.local (which is gitignored) and fill in your values.

# Private key for the deployer wallet on Somnia Shannon testnet.
# Generate a fresh testnet-only wallet — NEVER reuse a mainnet key.
# Get testnet STT from the Somnia faucet.
PRIVATE_KEY=

# RPC URL for Somnia Shannon. The default is the sponsor's public endpoint;
# override if you have a dedicated node.
SHANNON_RPC_URL=https://api.infra.testnet.somnia.network
