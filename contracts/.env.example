# Copy this file to .env.local (which is gitignored) and fill in your values.

# Private key for the deployer wallet on Somnia Shannon testnet.
# Generate a fresh testnet-only wallet — NEVER reuse a mainnet key.
# Get testnet STT from the Somnia faucet at https://testnet.somnia.network.
PRIVATE_KEY=

# Private key for the deliverer wallet used by demo-e2e.ts.
# For the hackathon demo this can be the same as PRIVATE_KEY (the same wallet plays both roles).
SCRAPER_PRIVATE_KEY=

# RPC + WebSocket endpoints for Shannon. Override only if you have dedicated infra.
SHANNON_RPC_URL=https://api.infra.testnet.somnia.network
SHANNON_WS_URL=wss://api.infra.testnet.somnia.network/ws

# Public URLs hosting the demo HTML pages used by demo-e2e.ts.
# DEMO_HAPPY_URL    must respond with HTML containing an <h1>Hello Auspex</h1>.
# DEMO_NEGATIVE_URL must respond with HTML that does NOT contain that exact H1.
# Quickest options: GitHub Gist raw URLs, GitHub Pages, or a free Vercel/Netlify static deploy.
DEMO_HAPPY_URL=
DEMO_NEGATIVE_URL=
